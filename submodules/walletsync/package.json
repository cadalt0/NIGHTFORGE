{
  "name": "midnightwalletsync",
  "version": "1.0.0",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "bin",
    "src",
    "README.md",
    "midnightwalletsync.config.json",
    ".env.example",
    "tsconfig.json"
  ],
  "bin": {
    "midnightsync": "bin/midnightsync.js"
  },
  "scripts": {
    "init": "NODE_OPTIONS=--no-deprecation tsx src/cli.ts init",
    "sync": "NODE_OPTIONS=--no-deprecation tsx src/cli.ts sync",
    "balance": "NODE_OPTIONS=--no-deprecation tsx src/cli.ts balance",
    "status": "NODE_OPTIONS=--no-deprecation tsx src/cli.ts status",
    "build": "npm run typecheck",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@midnight-ntwrk/compact-js": "2.5.0",
    "@midnight-ntwrk/ledger-v8": "8.0.3",
    "@midnight-ntwrk/midnight-js-contracts": "4.0.4",
    "@midnight-ntwrk/midnight-js-http-client-proof-provider": "4.0.4",
    "@midnight-ntwrk/midnight-js-indexer-public-data-provider": "4.0.4",
    "@midnight-ntwrk/midnight-js-level-private-state-provider": "4.0.4",
    "@midnight-ntwrk/midnight-js-network-id": "4.0.4",
    "@midnight-ntwrk/midnight-js-node-zk-config-provider": "4.0.4",
    "@midnight-ntwrk/testkit-js": "4.0.4",
    "@midnight-ntwrk/wallet-sdk-address-format": "3.1.0",
    "@midnight-ntwrk/wallet-sdk-facade": "3.0.0",
    "@midnight-ntwrk/wallet-sdk-hd": "3.0.1",
    "@midnight-ntwrk/wallet-sdk-unshielded-wallet": "2.1.0",
    "@scure/bip39": "2.0.1",
    "axios": "1.14.0",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "testcontainers": "11.13.0",
    "tsx": "4.21.0"
  },
  "devDependencies": {
    "@types/node": "25.5.2",
    "typescript": "6.0.2"
  }
}
