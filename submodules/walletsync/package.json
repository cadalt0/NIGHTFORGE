{
  "name": "midnightwalletsync",
  "version": "0.2.0",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "bin",
    "src",
    "README.md",
    "midnightwalletsync.config.json",
    ".env.example",
    "tsconfig.json"
  ],
  "bin": {
    "midnightsync": "bin/midnightsync.js"
  },
  "scripts": {
    "init": "NODE_OPTIONS=--no-deprecation tsx src/cli.ts init",
    "sync": "NODE_OPTIONS=--no-deprecation tsx src/cli.ts sync",
    "balance": "NODE_OPTIONS=--no-deprecation tsx src/cli.ts balance",
    "status": "NODE_OPTIONS=--no-deprecation tsx src/cli.ts status",
    "build": "npm run typecheck",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@midnight-ntwrk/compact-js": "latest",
    "@midnight-ntwrk/ledger-v8": "latest",
    "@midnight-ntwrk/midnight-js-contracts": "latest",
    "@midnight-ntwrk/midnight-js-http-client-proof-provider": "latest",
    "@midnight-ntwrk/midnight-js-indexer-public-data-provider": "latest",
    "@midnight-ntwrk/midnight-js-level-private-state-provider": "latest",
    "@midnight-ntwrk/midnight-js-network-id": "latest",
    "@midnight-ntwrk/midnight-js-node-zk-config-provider": "latest",
    "@midnight-ntwrk/testkit-js": "latest",
    "@midnight-ntwrk/wallet-sdk-address-format": "latest",
    "@midnight-ntwrk/wallet-sdk-facade": "latest",
    "@midnight-ntwrk/wallet-sdk-hd": "latest",
    "@midnight-ntwrk/wallet-sdk-unshielded-wallet": "latest",
    "@scure/bip39": "^2.0.1",
    "axios": "^1.14.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "testcontainers": "^11.13.0",
    "tsx": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "typescript": "latest"
  }
}
